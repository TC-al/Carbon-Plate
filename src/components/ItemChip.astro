---
// Renders a single food item chip. Used as a static reference; the live
// version on results uses Alpine to bind grams. Keeping this component
// for the index-page intro and for visual mocks.
const { name = 'food', grams = 100, kg = 0 } = Astro.props as {
  name?: string; grams?: number; kg?: number;
};
---
<div class="sticker inline-flex items-center gap-2 px-3 py-2">
  <span class="text-lg font-extrabold capitalize">{name}</span>
  <span class="chip">{grams}g</span>
  <span class="text-sm handwritten text-peach-500">{kg.toFixed(2)} kg CO₂</span>
</div>
