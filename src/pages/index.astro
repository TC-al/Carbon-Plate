---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlateIllustration from '../components/PlateIllustration.astro';
import StreakRow from '../components/StreakRow.astro';
import { FOOD_COEFFICIENTS } from '../lib/coefficients.ts';

// Ship the coefficient table to the client so Alpine can recompute live
// when the user edits grams. (Pocket calculator philosophy.)
const coefficientJson = JSON.stringify(FOOD_COEFFICIENTS);
---
<BaseLayout title="Carbon Plate · Snap your dinner.">
  <main
    class="max-w-3xl mx-auto px-5 py-8"
    x-data={`carbonPlate(${coefficientJson})`}
    x-init="boot()"
  >
    <!-- HERO -->
    <header class="text-center mb-6">
      <p class="handwritten text-peach-500 text-2xl">a tiny little climate calculator</p>
      <h1 class="text-5xl sm:text-6xl font-extrabold leading-tight mt-1">
        carbon <span class="squiggle">plate</span>
      </h1>
      <p class="mt-3 text-lg text-navy-700/80">
        Snap your dinner. We'll tell you what it cost the ocean.
      </p>
    </header>

    <!-- LANDING (when no items yet) -->
    <section x-show="step === 'landing'" x-transition>
      <div class="sticker p-6 sm:p-10 bg-white">
        <div class="flex flex-col sm:flex-row items-center gap-6">
          <PlateIllustration class="w-64 wobble" />
          <div class="flex-1 text-center sm:text-left">
            <h2 class="text-2xl font-extrabold">how it works</h2>
            <ol class="mt-2 space-y-1 text-navy-700/90">
              <li><span class="chip">1</span> snap your meal</li>
              <li><span class="chip">2</span> we sketch out the ingredients</li>
              <li><span class="chip">3</span> you get a CO₂ number, plus ocean stuff</li>
            </ol>
            <div class="mt-5 flex flex-wrap gap-3 justify-center sm:justify-start">
              <label class="btn-sticker bg-peach-200 cursor-pointer">
                Snap your meal
                <input type="file" accept="image/*" capture="environment" class="hidden"
                  @change="handleFile($event)" />
              </label>
              <button class="btn-sticker bg-seafoam-200" @click="useDemoImage()">Try a demo plate</button>
            </div>
            <p class="mt-3 handwritten text-sm text-navy-500/80" x-show="!hasKey">
              psst — running in demo mode (no API key set, that's fine!)
            </p>
          </div>
        </div>
      </div>

      <div class="mt-6">
        <StreakRow />
      </div>

      <div class="mt-8 grid sm:grid-cols-3 gap-4">
        <div class="sticker p-4 bg-seafoam-100">
          <h3 class="font-extrabold">handmade coefficients</h3>
          <p class="text-sm">~30 foods, sourced from Poore &amp; Nemecek and Our World in Data.</p>
        </div>
        <div class="sticker p-4 bg-peach-100">
          <h3 class="font-extrabold">no servers</h3>
          <p class="text-sm">Streaks live in your browser. We're a pocket calculator.</p>
        </div>
        <div class="sticker p-4 bg-white">
          <h3 class="font-extrabold">honest disclaimers</h3>
          <p class="text-sm">Numbers are estimates. Don't yell at us, yell at supply chains.</p>
        </div>
      </div>
    </section>

    <!-- ANALYZING -->
    <section x-show="step === 'analyzing'" x-transition class="text-center py-16">
      <PlateIllustration class="w-48 mx-auto wobble" />
      <p class="handwritten text-2xl mt-4 text-peach-500">sniffing your plate…</p>
      <p class="text-sm text-navy-700/70">(asking Claude what's on it)</p>
    </section>

    <!-- RESULTS -->
    <section x-show="step === 'results'" x-transition>
      <div class="sticker p-6 bg-white">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="handwritten text-peach-500 text-xl">your plate weighed</p>
            <p class="text-5xl font-extrabold leading-tight" x-text="totalKg().toFixed(2) + ' kg CO₂'"></p>
            <p class="text-sm text-navy-700/70" x-show="mock">(demo mode — deterministic mock)</p>
          </div>
          <button class="btn-sticker bg-cream text-sm" @click="reset()">Start over</button>
        </div>

        <div class="mt-5 grid sm:grid-cols-2 gap-3">
          <div class="rounded-squish bg-seafoam-100 border-2 border-navy-700 p-4">
            <p class="handwritten text-navy-700 text-lg">phytoplankton needed</p>
            <p class="text-2xl font-extrabold" x-text="phyto().toFixed(1) + ' m²'"></p>
            <p class="text-xs">working all year to undo this meal</p>
          </div>
          <div class="rounded-squish bg-peach-100 border-2 border-navy-700 p-4">
            <p class="handwritten text-navy-700 text-lg">like driving</p>
            <p class="text-2xl font-extrabold" x-text="km().toFixed(1) + ' km'"></p>
            <p class="text-xs">in an average passenger car</p>
          </div>
        </div>

        <h3 class="mt-6 font-extrabold text-lg">items</h3>
        <p class="text-sm text-navy-700/70">tap a number to fix our guess.</p>
        <ul class="mt-2 space-y-2">
          <template x-for="(it, idx) in items" :key="idx">
            <li class="sticker bg-cream p-3 flex flex-wrap items-center gap-3">
              <span class="text-xl font-extrabold capitalize" x-text="it.name"></span>
              <span class="chip flex items-center gap-1">
                <input type="number" min="1" step="5"
                  class="w-16 bg-transparent text-right outline-none font-bold"
                  x-model.number="it.grams" />
                <span>g</span>
              </span>
              <span class="handwritten text-peach-500 ml-auto" x-text="kgFor(it).toFixed(2) + ' kg'"></span>
              <button @click="items.splice(idx,1)" class="text-navy-500/60 hover:text-peach-500" aria-label="remove">×</button>
            </li>
          </template>
        </ul>

        <div class="mt-5 flex flex-wrap gap-3">
          <button class="btn-sticker bg-seafoam-200" @click="saveToStreak()" x-show="!savedTodayFlag">
            Save to my streak
          </button>
          <span class="handwritten text-seafoam-500 text-lg" x-show="savedTodayFlag">saved! 🎉</span>
          <button class="btn-sticker bg-peach-200" @click="askForSwaps()" :disabled="loadingSwaps">
            <span x-show="!loadingSwaps">Suggest a swap</span>
            <span x-show="loadingSwaps">thinking…</span>
          </button>
        </div>

        <div class="mt-5" x-show="swaps.length">
          <h3 class="font-extrabold text-lg">three little swaps</h3>
          <ul class="mt-2 space-y-2">
            <template x-for="(s, i) in swaps" :key="i">
              <li class="rounded-squish border-2 border-navy-700 bg-white p-3">
                <p class="font-extrabold">
                  <span class="line-through text-navy-500/60" x-text="s.from"></span>
                  →
                  <span class="text-seafoam-500" x-text="s.to"></span>
                </p>
                <p class="text-sm handwritten text-navy-700/80" x-text="s.why"></p>
              </li>
            </template>
          </ul>
        </div>
      </div>

      <div class="mt-6">
        <StreakRow />
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ COEFFS: FOOD_COEFFICIENTS }}>
    // Alpine factories. Inline so we don't need a build step for client JS.
    document.addEventListener('alpine:init', () => {
      const STORAGE_KEY = 'carbon-plate.streak.v1';

      function todayKey() {
        const d = new Date();
        return d.toISOString().slice(0, 10);
      }

      function loadStreak() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; }
        catch { return {}; }
      }
      function saveStreak(s) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
      }

      function lookup(name) {
        const n = (name || '').toLowerCase().trim();
        if (COEFFS[n] != null) return COEFFS[n];
        for (const k of Object.keys(COEFFS)) {
          if (n.includes(k) || k.includes(n)) return COEFFS[k];
        }
        return 0.25; // unknown baseline
      }

      Alpine.data('carbonPlate', (coeffs) => ({
        step: 'landing',
        items: [],
        swaps: [],
        loadingSwaps: false,
        mock: false,
        hasKey: false,
        savedTodayFlag: false,

        boot() {
          // Detect if today already saved so we don't double-add.
          const s = loadStreak();
          this.savedTodayFlag = !!s[todayKey()];
          // We don't actually know the API key client-side; assume mock unless server says otherwise.
          this.hasKey = false;
        },

        kgFor(it) {
          return (lookup(it.name) * (it.grams || 0)) / 100;
        },
        totalKg() {
          return this.items.reduce((s, i) => s + this.kgFor(i), 0);
        },
        phyto() { return this.totalKg() * 5.46; },
        km() { return this.totalKg() / 0.17; },

        async handleFile(ev) {
          const f = ev.target.files?.[0];
          if (!f) return;
          this.step = 'analyzing';
          const b64 = await fileToBase64(f);
          await this.callAnalyze(b64, f.type || 'image/jpeg');
        },

        async useDemoImage() {
          this.step = 'analyzing';
          // Tiny placeholder PNG so the API endpoint can deterministically pick a meal.
          const seed = Math.floor(Math.random() * 5);
          const dummy = 'iVBORw0KGgoAAAANSUhEUgAAAA' + 'AB'.repeat(seed + 1) + 'AAAACklEQVR4nGMAAQAABQABDQottAAAAABJRU5ErkJggg==';
          await this.callAnalyze(dummy, 'image/png');
        },

        async callAnalyze(imageBase64, mediaType) {
          try {
            const r = await fetch('/api/analyze', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ imageBase64, mediaType }),
            });
            const data = await r.json();
            this.items = (data.items || []).map(it => ({
              name: it.name, grams: it.grams, confidence: it.confidence,
            }));
            this.mock = !!data.mock;
            this.hasKey = !data.mock;
            this.swaps = [];
            this.step = 'results';
          } catch (e) {
            console.error(e);
            this.step = 'landing';
            alert("Hmm — couldn't analyze that. Try again?");
          }
        },

        async askForSwaps() {
          this.loadingSwaps = true;
          try {
            const r = await fetch('/api/swap', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ items: this.items.map(i => ({ name: i.name, grams: i.grams })) }),
            });
            const data = await r.json();
            this.swaps = data.swaps || [];
          } finally {
            this.loadingSwaps = false;
          }
        },

        saveToStreak() {
          const s = loadStreak();
          s[todayKey()] = { kg: this.totalKg(), items: this.items.length, ts: Date.now() };
          saveStreak(s);
          this.savedTodayFlag = true;
          // Tell any StreakRow on the page to refresh.
          window.dispatchEvent(new CustomEvent('streak:update'));
        },

        reset() {
          this.items = [];
          this.swaps = [];
          this.step = 'landing';
          this.mock = false;
          this.savedTodayFlag = !!loadStreak()[todayKey()];
        },
      }));

      Alpine.data('streak', () => ({
        days: [],
        load() {
          const s = loadStreak();
          const out = [];
          const now = new Date();
          for (let i = 6; i >= 0; i--) {
            const d = new Date(now);
            d.setDate(now.getDate() - i);
            const k = d.toISOString().slice(0, 10);
            const dayName = d.toLocaleDateString(undefined, { weekday: 'short' });
            out.push({ key: k, label: dayName, kg: s[k]?.kg || 0 });
          }
          this.days = out;
          window.addEventListener('streak:update', () => this.load(), { once: true });
        },
        streakLabel() {
          const active = this.days.filter(d => d.kg > 0).length;
          if (!active) return 'no plates yet';
          if (active === 7) return 'full week!';
          return active + ' / 7 days';
        },
      }));
    });

    function fileToBase64(file) {
      return new Promise((resolve, reject) => {
        const r = new FileReader();
        r.onload = () => {
          const s = String(r.result || '');
          const i = s.indexOf(',');
          resolve(i >= 0 ? s.slice(i + 1) : s);
        };
        r.onerror = reject;
        r.readAsDataURL(file);
      });
    }
  </script>
</BaseLayout>
