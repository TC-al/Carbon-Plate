---
// 7-day streak — the *real* DOM is rebuilt on the client by Alpine
// from localStorage. This component just paints the empty scaffolding so
// the page doesn't flicker on first paint.
---
<div
  x-data="streak()"
  x-init="load()"
  class="sticker p-4 bg-white"
  aria-label="Last 7 days of meals"
>
  <div class="flex items-center justify-between mb-3">
    <h3 class="font-extrabold text-lg">Last 7 days</h3>
    <span class="handwritten text-peach-500 text-lg" x-text="streakLabel()"></span>
  </div>
  <div class="flex items-end gap-2 justify-between">
    <template x-for="(day, i) in days" :key="i">
      <div class="flex flex-col items-center gap-1 flex-1">
        <!-- mini plate -->
        <svg viewBox="0 0 60 40" class="w-full max-w-[56px]" :class="day.kg > 0 ? '' : 'opacity-40'">
          <ellipse cx="30" cy="22" rx="26" ry="10" fill="#fff" stroke="#0e1c34" stroke-width="2"/>
          <ellipse cx="30" cy="20" rx="22" ry="8"
            :fill="day.kg > 4 ? '#ff8a3d' : day.kg > 2 ? '#ffc89b' : day.kg > 0 ? '#a9e3c1' : '#f3f3f3'"
            stroke="#0e1c34" stroke-width="1.5"/>
        </svg>
        <span class="text-[10px] uppercase tracking-wide font-bold" x-text="day.label"></span>
        <span class="handwritten text-xs text-navy-700" x-text="day.kg ? day.kg.toFixed(1) + 'kg' : '–'"></span>
      </div>
    </template>
  </div>
</div>
