---
// A hand-drawn plate with a fish, a leaf, and a bubble of steam.
// All inline SVG. No stock images allowed in this app.
const { class: className = '' } = Astro.props as { class?: string };
---
<svg viewBox="0 0 320 280" class={className} xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <filter id="rough" x="-10%" y="-10%" width="120%" height="120%">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="3"/>
      <feDisplacementMap in="SourceGraphic" scale="1.4"/>
    </filter>
  </defs>
  <!-- steam swirls -->
  <g stroke="#1f3a5f" stroke-width="2.5" fill="none" stroke-linecap="round">
    <path d="M120 40 q 8 -10 0 -20 q -8 -10 0 -20" />
    <path d="M160 30 q 8 -10 0 -20 q -8 -10 0 -20" />
    <path d="M200 40 q 8 -10 0 -20 q -8 -10 0 -20" />
  </g>
  <!-- shadow -->
  <ellipse cx="160" cy="245" rx="120" ry="10" fill="#1f3a5f" opacity="0.12"/>
  <!-- plate rim -->
  <ellipse cx="160" cy="170" rx="135" ry="55" fill="#fff" stroke="#0e1c34" stroke-width="3" filter="url(#rough)"/>
  <!-- plate dish -->
  <ellipse cx="160" cy="165" rx="115" ry="42" fill="#ffe6d1" stroke="#0e1c34" stroke-width="3"/>
  <!-- fish -->
  <g transform="translate(95 145) rotate(-8)" filter="url(#rough)">
    <path d="M0 15 q 25 -25 60 0 q -25 25 -60 0 z" fill="#7ad4a1" stroke="#0e1c34" stroke-width="2.5"/>
    <path d="M60 15 l 18 -10 l 0 20 z" fill="#7ad4a1" stroke="#0e1c34" stroke-width="2.5"/>
    <circle cx="15" cy="12" r="2.5" fill="#0e1c34"/>
    <path d="M28 12 q 5 -3 10 0" stroke="#0e1c34" stroke-width="1.5" fill="none"/>
  </g>
  <!-- leaf -->
  <g transform="translate(195 140) rotate(20)">
    <path d="M0 0 q 25 -20 50 0 q -25 20 -50 0 z" fill="#52c084" stroke="#0e1c34" stroke-width="2.5"/>
    <path d="M5 0 q 20 0 40 0" stroke="#0e1c34" stroke-width="1.5" fill="none"/>
  </g>
  <!-- little dot garnish -->
  <circle cx="160" cy="185" r="3" fill="#f06f1f" stroke="#0e1c34" stroke-width="1.5"/>
  <circle cx="145" cy="190" r="2" fill="#f06f1f" stroke="#0e1c34" stroke-width="1"/>
  <circle cx="175" cy="190" r="2" fill="#f06f1f" stroke="#0e1c34" stroke-width="1"/>
</svg>
